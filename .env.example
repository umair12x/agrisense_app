# Copy to .env and fill in values before building:
#   cp .env.example .env
#
# For EAS cloud builds, either:
#   1) Push env to Expo:  eas env:push --environment production --path .env
#   2) Or rely on eas.json production profile env (defaults below)

# --- Required API endpoints (bundled into the APK at build time) ---
EXPO_PUBLIC_RAG_API_URL=https://agrisence.onrender.com
EXPO_PUBLIC_DISEASE_API_URL=https://agrisence-plant-disease-detection.onrender.com
EXPO_PUBLIC_APP_API_URL=https://agrisence-backend.onrender.com/api

# --- Optional: legacy Next.js-style keys (fallback in src/utils/api.js) ---


# --- Optional: Cloudinary (community media uploads) ---
EXPO_PUBLIC_CLOUDINARY_CLOUD_NAME=
EXPO_PUBLIC_CLOUDINARY_UPLOAD_PRESET=
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=

# --- Android / EAS (optional) ---
EXPO_ANDROID_PACKAGE=com.agrisense.app
EXPO_ANDROID_VERSION_CODE=1
# EAS_PROJECT_ID=your-expo-project-uuid
