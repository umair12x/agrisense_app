{
  "expo": {
    "name": "AgriSense",
    "slug": "agrisenseapp",
    "version": "5.2.1",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ecfdf5"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSAppTransportSecurity": {
          "NSAllowsLocalNetworking": true
        }
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ecfdf5"
      },
      "edgeToEdgeEnabled": true,
      "usesCleartextTraffic": false,
      "softwareKeyboardLayoutMode": "resize"
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow AgriSense to access your photos and videos for disease detection and community posts.",
          "cameraPermission": "Allow AgriSense to access your camera for disease detection and community posts.",
          "microphonePermission": "Allow AgriSense to record audio when capturing videos for community posts."
        }
      ],
      "expo-secure-store",
      "expo-splash-screen",
      "expo-audio",
      "expo-video"
    ],
    "web": {
      "favicon": "./assets/favicon.png"
    }
  }
}
